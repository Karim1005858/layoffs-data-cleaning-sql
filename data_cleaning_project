-- Create a staging table with same structure as original
create table  layoff_staging
like world_layoff.layoffs;

-- Preview original data
select *
from world_layoff.layoffs;

-- Insert data into staging table
insert layoff_staging
select *
from world_layoff.layoffs;

-------------- remove duplicates

-- Identify duplicates using ROW_NUMBER
with duplicate_cte as(
select*,row_number() over( partition by company,location,industry,total_laid_off,percentage_laid_off,date,stage,country,funds_raised_millions) as rn
from world_layoff.layoff_staging)
select *
from duplicate_cte
where rn>1;

-- View staging table
select*
from world_layoff.layoff_staging;

-- View second staging table
select *
from world_layoff.layoff_staging2;

-- Show all tables in database
SHOW TABLES FROM world_layoff;

-- Create new table with additional row_num column
CREATE TABLE world_layoff.layoff_staging2 (
  company text,
  location text,
  industry text,
  total_laid_off int DEFAULT NULL,
  percentage_laid_off text,
  date text,
  stage text,
  country text,
  funds_raised_millions int DEFAULT NULL,
  row_num int
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

-- Preview new table
select *
from world_layoff.layoff_staging2;

-- Insert data and assign row number for duplicate detection
insert into world_layoff.layoff_staging2
select * ,
row_number() over( partition by company,location,industry,total_laid_off,percentage_laid_off,date,stage,country,funds_raised_millions) as 'row_num'
from world_layoff.layoff_staging;

-- Delete duplicate rows
delete 
from world_layoff.layoff_staging2
where row_num>1;

-- View cleaned data
select *
from world_layoff.layoff_staging2;

-------- standardized

-- Check company names before and after TRIM
select company ,trim(company)
from world_layoff.layoff_staging2;

-- Remove leading/trailing spaces in company names
update  world_layoff.layoff_staging2
set company =trim(company);

-- Find crypto-related industry values
select *
from world_layoff.layoff_staging2
where industry like "crypto%";

-- Standardize crypto industry naming
update world_layoff.layoff_staging2
set industry ="crypto"
where industry like "crypto%";

-- View distinct country values
select distinct country 
from world_layoff.layoff_staging2
order by 1;

-- Remove trailing dot in United States
update world_layoff.layoff_staging2
set country = trim(trailing "."from country)
where country like "United States%";

-- Convert date from text to proper date format
select date,str_to_date(date,"%m/%d/%Y")
from  world_layoff.layoff_staging2;

-- Update date column with converted format
update world_layoff.layoff_staging2
set  date=str_to_date(date,"%m/%d/%Y");

-- Change column type to DATE
Alter table world_layoff.layoff_staging2
modify column date date;

--------  remove null values

-- Find rows where both total and percentage laid off are null
select *
from world_layoff.layoff_staging2
where total_laid_off is null and percentage_laid_off is null ;

-- Find rows with missing industry
select *
from world_layoff.layoff_staging2
where industry is null;

-- Example check for specific company
select *
from world_layoff.layoff_staging2
where company = "Airbnb";

-- Convert empty industry values to NULL
update world_layoff.layoff_staging2
set industry = null
where industry ="";

-- Match missing industries with available ones from same company
SELECT t1.industry, t2.industry
FROM world_layoff.layoff_staging2 t1
JOIN world_layoff.layoff_staging2 t2
    ON t1.company = t2.company
WHERE (t1.industry IS NULL OR t1.industry = '')
AND t2.industry IS NOT NULL;

-- Fill missing industry values using self join
UPDATE world_layoff.layoff_staging2 t1
JOIN world_layoff.layoff_staging2 t2
    ON t1.company = t2.company
SET t1.industry = t2.industry
WHERE (t1.industry IS NULL OR t1.industry = '')
AND t2.industry IS NOT NULL;

-- Remove rows where both layoff values are null
delete 
from world_layoff.layoff_staging2
where total_laid_off is null and percentage_laid_off is null ;

-- Drop helper column used for duplicate removal
alter table world_layoff.layoff_staging2
drop column row_num;
